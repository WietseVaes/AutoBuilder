   "source": [
    "import numpy as np\n",
    "\n",
    "A = np.array([[0.75, 1.0], [-1.0, -0.5]])\n",
    "\n",
    "\n",
    "def rk4_step(y0, dt):\n",
    "    y0 = np.array(y0, dtype=float)\n",
    "    k1 = A @ y0\n",
    "    k2 = A @ (y0 + dt / 2 * k1)\n",
    "    k3 = A @ (y0 + dt / 2 * k2)\n",
    "    k4 = A @ (y0 + dt * k3)\n",
    "    return y0 + dt / 6 * (k1 + 2 * k2 + 2 * k3 + k4)\n"
   ]
  }
